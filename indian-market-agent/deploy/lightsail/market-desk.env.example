# Runtime
MARKET_DESK_DATA_DIR=/srv/indian-news-bot/indian-market-news-bot/backend/data
MARKET_DESK_DISABLE_THREADS=1

# Market data
MARKET_DATA_PROVIDER=upstox
UPSTOX_FALLBACK_TO_NSE=1

# Upstox market data. Use the long-lived read-only Analytics Token only.
UPSTOX_ANALYTICS_TOKEN=
# auto tries Python requests first and falls back to system curl if Upstox's edge returns HTML 403.
UPSTOX_HTTP_TRANSPORT=auto
# Keep this curl-like default unless Upstox support asks you to change it.
UPSTOX_USER_AGENT=curl/8.7.1

# AI summaries and article impact analysis.
# Use AI_PROVIDER=bedrock in production, or AI_PROVIDER=ollama for local/dev.
ENABLE_AI_NEWS_SUMMARIES=1
ENABLE_ARTICLE_EXTRACTION=1
AI_PROVIDER=bedrock

# Bedrock production provider. Prefer IAM credentials or an instance role where available.
BEDROCK_REGION=ap-south-1
BEDROCK_MODEL_ID=qwen.qwen3-next-80b-a3b
BEDROCK_TIMEOUT_SECONDS=120
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# Optional Bedrock API-key quickstart provider.
# Set AI_PROVIDER=bedrock-api-key if you want to use the Bedrock API key screen.
# BEDROCK_API_KEY=
# BEDROCK_OPENAI_BASE_URL=https://bedrock-mantle.ap-south-1.api.aws/v1
# Qwen supports Chat Completions on Bedrock Mantle, not Responses.
# BEDROCK_MANTLE_MODEL_ID=qwen.qwen3-next-80b-a3b-instruct
# BEDROCK_OPENAI_API=chat_completions

# AI chat terminal. Keep this separate from article summaries so chat can use
# Bedrock while summaries can stay on Ollama or another provider.
AI_CHAT_PROVIDER=bedrock-api-key
AI_CHAT_MODEL=qwen.qwen3-next-80b-a3b-instruct
AI_CHAT_MAX_WEB_RESULTS=6
AI_CHAT_MAX_TOKENS=750

# Local open-source fallback. Use qwen2.5:3b on smaller instances.
OLLAMA_API_BASE=http://127.0.0.1:11434/api
OLLAMA_NEWS_SUMMARY_MODEL=qwen2.5:7b
OLLAMA_SUMMARY_TIMEOUT_SECONDS=120
OLLAMA_SUMMARY_NUM_PREDICT=320
MAX_AI_SUMMARY_WORKERS=1
AI_SUMMARY_WINDOW_HOURS=24
