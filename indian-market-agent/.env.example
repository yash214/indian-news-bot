# Runtime / Flask
PYTHONUNBUFFERED=1
HOST=127.0.0.1
PORT=9090
MARKET_DESK_DATA_DIR=backend/data
MARKET_DESK_HOLIDAY_FILE=backend/data/nse_holidays.json
MARKET_DESK_DISABLE_THREADS=0
GLOBAL_QUOTE_REFRESH_SECONDS=5.0
STREAM_UI_BROADCAST_SECONDS=1.0

# Market data provider
# MARKET_DATA_PROVIDER can be nse or upstox.
MARKET_DATA_PROVIDER=nse
UPSTOX_ANALYTICS_TOKEN=
UPSTOX_FALLBACK_TO_NSE=1
UPSTOX_DEBUG=0
UPSTOX_HTTP_TRANSPORT=auto
UPSTOX_USER_AGENT=curl/8.7.1
UPSTOX_API_BASE=https://api.upstox.com/v2
UPSTOX_V3_API_BASE=
UPSTOX_INSTRUMENT_KEYS=
UPSTOX_OPTION_EXPIRY=

# Upstox read-only market data / options providers
UPSTOX_MARKET_DATA_ENABLED=false
UPSTOX_MARKET_DATA_TIMEOUT_SECONDS=8
UPSTOX_MARKET_DATA_CACHE_TTL_SECONDS=300
UPSTOX_OPTIONS_ENABLED=false
UPSTOX_OPTIONS_TIMEOUT_SECONDS=8
UPSTOX_OPTIONS_CACHE_TTL_SECONDS=300

# Macro/context providers
FMP_ENABLED=false
FMP_API_KEY=
FMP_TIMEOUT_SECONDS=8
FMP_CACHE_TTL_SECONDS=3600
RBI_PROVIDER_ENABLED=false
RBI_PROVIDER_TIMEOUT_SECONDS=8
RBI_PROVIDER_CACHE_TTL_SECONDS=86400
MOSPI_PROVIDER_ENABLED=false
MOSPI_PROVIDER_TIMEOUT_SECONDS=8
MOSPI_PROVIDER_CACHE_TTL_SECONDS=86400
NSDL_PROVIDER_ENABLED=false
NSDL_PROVIDER_TIMEOUT_SECONDS=8
NSDL_PROVIDER_CACHE_TTL_SECONDS=86400
CCIL_PROVIDER_ENABLED=false
CCIL_PROVIDER_TIMEOUT_SECONDS=8
CCIL_PROVIDER_CACHE_TTL_SECONDS=3600

# Macro Context Agent
MACRO_AGENT_ENABLED=true
MACRO_AGENT_REFRESH_MODE=scheduled
MACRO_AGENT_PREMARKET_TIME=08:35
MACRO_AGENT_OPEN_CHECK_TIME=09:25
MACRO_AGENT_MIDDAY_TIME=12:30
MACRO_AGENT_PRE_CLOSE_TIME=15:00
MACRO_AGENT_POSTMARKET_TIME=15:45
MACRO_AGENT_TIMEZONE=Asia/Kolkata
MACRO_AGENT_SNAPSHOT_TTL_SECONDS=5400

# F&O Structure Agent
FO_AGENT_ENABLED=true
FO_AGENT_REFRESH_SECONDS=300
FO_AGENT_TIMEZONE=Asia/Kolkata

# Market Regime Agent
MARKET_REGIME_AGENT_ENABLED=true
MARKET_REGIME_REFRESH_SECONDS=300
MARKET_REGIME_TIMEFRAME_MINUTES=5
MARKET_REGIME_TIMEZONE=Asia/Kolkata

# AI provider selection
# AI_PROVIDER can be ollama, bedrock, or bedrock-api-key.
ENABLE_AI_NEWS_SUMMARIES=1
ENABLE_ARTICLE_EXTRACTION=1
AI_PROVIDER=ollama
AI_CHAT_PROVIDER=
AI_CHAT_MODEL=
AI_CHAT_MAX_HISTORY=8
AI_CHAT_MAX_CONTEXT_ARTICLES=10
AI_CHAT_MAX_WEB_RESULTS=6
AI_CHAT_WEB_CACHE_TTL=180
AI_CHAT_CONTEXT_CHAR_LIMIT=14000
AI_CHAT_MAX_TOKENS=750

# OpenAI-compatible provider fallback values
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Amazon Bedrock / Bedrock API-key provider
BEDROCK_REGION=ap-south-1
BEDROCK_MODEL_ID=qwen.qwen3-next-80b-a3b
BEDROCK_MANTLE_MODEL_ID=qwen.qwen3-next-80b-a3b-instruct
BEDROCK_TIMEOUT_SECONDS=120
BEDROCK_PROFILE_NAME=
BEDROCK_API_KEY=
BEDROCK_OPENAI_BASE_URL=https://bedrock-mantle.ap-south-1.api.aws/v1
BEDROCK_RESPONSES_BASE_URL=
BEDROCK_OPENAI_API=chat_completions
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# Local Ollama provider
OLLAMA_API_BASE=http://127.0.0.1:11434/api
OLLAMA_NEWS_SUMMARY_MODEL=qwen2.5:3b
OLLAMA_SUMMARY_KEEP_ALIVE=15m
OLLAMA_SUMMARY_TIMEOUT_SECONDS=90
OLLAMA_SUMMARY_NUM_PREDICT=320

# AI summary queue and article extraction
MAX_AI_SUMMARY_WORKERS=1
MAX_AI_SUMMARY_ARTICLES=500
AI_SUMMARY_SYNC_ARTICLES=0
AI_SUMMARY_WINDOW_HOURS=24
AI_SUMMARY_RETRY_AFTER_SECONDS=45
AI_SUMMARY_QUEUE_RETRY_BASE_SECONDS=120
AI_SUMMARY_QUEUE_MAX_BACKOFF_SECONDS=1800
AI_SUMMARY_MAX_INPUT_CHARS=4500
ARTICLE_EXTRACTION_TIMEOUT_SECONDS=3
ARTICLE_EXTRACTION_MIN_CHARS=500
ARTICLE_EXTRACTION_MAX_CHARS=7000
